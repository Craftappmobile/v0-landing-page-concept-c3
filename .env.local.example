# ============================================================
# ЛОКАЛЬНИЙ ШАБЛОН ЗМІННИХ СЕРЕДОВИЩА
# Скопіюйте цей файл у .env.local і заповніть значення
# НЕ КОМІТЬТЕ .env.local у Git
# ============================================================

# --- Supabase ---
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Тільки для server-side route handlers
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Hutko ---
# Merchant credentials для checkout / callback / recurring
HUTKO_MERCHANT_ID=1234567
HUTKO_MERCHANT_PASSWORD=your_hutko_secret

# --- Email (Resend) ---
RESEND_API_KEY=re_...

# --- Site / Cron ---
# Production base URL without trailing slash.
# Використовується recurring route для callback URL.
NEXT_PUBLIC_SITE_URL=https://vjazhi.com.ua

# Secret for GET /api/payment/recurring
CRON_SECRET=replace-with-strong-random-value